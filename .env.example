# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=30

# ── Celery workers ────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=1

# ── OpenCode ──────────────────────────────────────────────────────────────────
# Binario dentro del contenedor (instalado por el Dockerfile)
OPENCODE_BIN=opencode

# Timeouts por rol (segundos)
TIMEOUT_TEST_ENGINEER=1800
TIMEOUT_DEVELOPER=3600
TIMEOUT_TESTER=1800
TIMEOUT_ATF=1800

# ── Telegram ──────────────────────────────────────────────────────────────────
# Obtener token: hablar con @BotFather en Telegram
# Obtener chat_id: enviar un mensaje al bot y consultar
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Git sync ──────────────────────────────────────────────────────────────────
GIT_USER_NAME=atdd-orchestrator
GIT_USER_EMAIL=atdd@orchestrator.local
PROJECTS_FILE=/app/projects.yml

# ── Volúmenes (rutas en el host) ──────────────────────────────────────────────
# Directorio raíz donde viven los proyectos en el servidor
PROJECTS_ROOT=/srv/projects

# Directorio de skills de Claude Code en el servidor
SKILLS_DIR=/root/.claude/skills

# Directorio de configuración de OpenCode (contiene API keys)
OPENCODE_CONFIG_DIR=/root/.config/opencode
